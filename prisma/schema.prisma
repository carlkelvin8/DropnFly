generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  EMPLOYEE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  RECEIVED
  IN_STORAGE
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  NO_SHOW
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(EMPLOYEE)
  isApproved   Boolean   @default(false)
  isActive     Boolean   @default(true)
  currentLat          Float?
  currentLng          Float?
  lastLocationUpdate  DateTime?
  profilePic          String?
  vehicleType         String?
  plateNumber         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings          Booking[]
  activityLogs      ActivityLog[]
  assignedBookings  BookingAssignment[]
  locationUpdates   LocationUpdate[]
  notifications     Notification[]
  extensionReviews  BookingExtension[]
  chatMessages      ChatMessage[]
  scanEvents        ScanEvent[]
  incidentTimelines IncidentTimeline[]
}

model StorageLocation {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  capacity     Int
  pricePerDay  Float
  openingTime  String   @default("08:00")
  closingTime  String   @default("20:00")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings Booking[]
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String
  password        String?
  countryOfOrigin String?
  cityOfOrigin    String?
  isApproved      Boolean  @default(true)
  isActive        Boolean  @default(true)
  image           String?
  points          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings          Booking[]
  payments          Payment[]
  notifications     CustomerNotification[]
  chatMessages      ChatMessage[]
  reviews           BookingReview[]
  pointsTransactions PointsTransaction[]
  incidentReports   IncidentReport[]
}

model Booking {
  id              String        @id @default(cuid())
  referenceNumber String        @unique
  qrCode          String
  userId          String?
  customerId      String
  locationId      String?
  pickupLocation  String
  dropOffLocation String
  luggageDetails  String?
  luggagePhotos   String[]
  checkIn         DateTime
  checkOut        DateTime?
  numberOfBags    Int
  totalPrice      Float         @default(0)
  discount        Float         @default(0)
  promoCodeId     String?
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user       User?            @relation(fields: [userId], references: [id])
  customer   Customer         @relation(fields: [customerId], references: [id])
  location   StorageLocation? @relation(fields: [locationId], references: [id])
  promoCode  PromoCode?       @relation(fields: [promoCodeId], references: [id])
  payments   Payment[]
  assignments BookingAssignment[]
  extensions BookingExtension[]
  chatMessages     ChatMessage[]
  review           BookingReview?
  luggageItems     LuggageItem[]
  scanEvents       ScanEvent[]
  baggageTags      BaggageTag[]
  incidentReports  IncidentReport[]
}

model ScanEvent {
  id          String   @id @default(cuid())
  bookingId   String
  userId      String?
  status      String   // PENDING, CONFIRMED, RECEIVED, IN_STORAGE, OUT_FOR_DELIVERY, DELIVERED
  photo       String?  // base64 photo proof
  note        String?
  latitude    Float?
  longitude   Float?
  scannedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@index([bookingId, scannedAt])
}

model BookingAssignment {
  id        String   @id @default(cuid())
  bookingId String
  userId    String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model LocationUpdate {
  id        String   @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  GCASH
  MAYA
  CARD
  CASH
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  customerId    String
  amount        Float
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  reference     String?
  gatewayRef    String?       @unique
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id          String       @id @default(cuid())
  code        String       @unique
  description String?
  type        DiscountType @default(PERCENTAGE)
  value       Float
  maxUsage    Int          @default(100)
  usedCount   Int          @default(0)
  minAmount   Float        @default(0)
  maxDiscount Float?
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bookings Booking[]
}

model CustomerNotification {
  id        String   @id @default(cuid())
  customerId String
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  customerId String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([customerId])
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

model BookingExtension {
  id                String          @id @default(cuid())
  bookingId         String
  requestedCheckOut DateTime
  reason            String?
  status            ExtensionStatus @default(PENDING)
  requestedAt       DateTime        @default(now())
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  booking    Booking @relation(fields: [bookingId], references: [id])
  reviewedBy User?   @relation(fields: [reviewedById], references: [id])

  @@index([bookingId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  bookingId      String
  senderId       String?
  customerId     String?
  message        String
  isFromCustomer Boolean  @default(false)
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  booking  Booking   @relation(fields: [bookingId], references: [id])
  sender   User?     @relation(fields: [senderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([bookingId, createdAt])
}

model BookingReview {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([bookingId])
}

model PointsTransaction {
  id          String   @id @default(cuid())
  customerId  String
  points      Int
  type        String   @default("EARNED")
  reference   String?
  description String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

model LuggageItem {
  id          String    @id @default(cuid())
  bookingId   String
  tagNumber   String    @unique
  description String?
  status      String    @default("CHECKED_IN")
  location    String?
  checkInAt   DateTime  @default(now())
  checkOutAt  DateTime?
  flag        String? // LOST, DAMAGED, null
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  booking      Booking       @relation(fields: [bookingId], references: [id])
  baggageTag   BaggageTag?

  @@index([bookingId])
  @@index([tagNumber])
}

model BaggageTag {
  id            String    @id @default(cuid())
  tagNumber     String    @unique
  status        String    @default("AVAILABLE") // AVAILABLE, ASSIGNED, RETIRED, LOST
  bookingId     String?
  luggageItemId String?   @unique
  assignedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  booking     Booking?     @relation(fields: [bookingId], references: [id])
  luggageItem LuggageItem? @relation(fields: [luggageItemId], references: [id])

  @@index([status])
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  CLOSED
}

model IncidentReport {
  id            String          @id @default(cuid())
  bookingId     String
  customerId    String
  type          String          // lost_baggage, damaged_baggage, service_complaint, other
  description   String
  priority      IncidentPriority @default(MEDIUM)
  status        IncidentStatus   @default(PENDING)
  internalNotes String?
  resolution    String?
  escalatedTo   String?         // userId escalation is sent to
  submittedAt   DateTime        @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  booking  Booking            @relation(fields: [bookingId], references: [id])
  customer Customer           @relation(fields: [customerId], references: [id])
  timeline IncidentTimeline[]

  @@index([bookingId])
  @@index([status])
  @@index([priority])
}

model IncidentTimeline {
  id          String   @id @default(cuid())
  incidentId  String
  action      String   // created, status_change, note_added, photo_uploaded, resolved
  description String
  userId      String?
  createdAt   DateTime @default(now())

  incident IncidentReport @relation(fields: [incidentId], references: [id])
  user     User?          @relation(fields: [userId], references: [id])

  @@index([incidentId])
}
