generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  EMPLOYEE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  RECEIVED
  IN_STORAGE
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(EMPLOYEE)
  isApproved   Boolean   @default(false)
  isActive     Boolean   @default(true)
  currentLat   Float?
  currentLng   Float?
  lastLocationUpdate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bookings          Booking[]
  activityLogs      ActivityLog[]
  assignedBookings  BookingAssignment[]
  locationUpdates   LocationUpdate[]
  notifications     Notification[]
}

model StorageLocation {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  capacity     Int
  pricePerDay  Float
  openingTime  String   @default("08:00")
  closingTime  String   @default("20:00")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings Booking[]
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String
  password        String?
  isApproved      Boolean  @default(true)
  isActive        Boolean  @default(true)
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        Booking[]
  payments        Payment[]
  notifications   CustomerNotification[]
}

model Booking {
  id              String        @id @default(cuid())
  referenceNumber String        @unique
  qrCode          String
  userId          String?
  customerId      String
  locationId      String?
  pickupLocation  String
  dropOffLocation String
  luggageDetails  String?
  luggagePhotos   String[]
  checkIn         DateTime
  checkOut        DateTime?
  numberOfBags    Int
  totalPrice      Float         @default(0)
  discount        Float         @default(0)
  promoCodeId     String?
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user       User?            @relation(fields: [userId], references: [id])
  customer   Customer         @relation(fields: [customerId], references: [id])
  location   StorageLocation? @relation(fields: [locationId], references: [id])
  promoCode  PromoCode?       @relation(fields: [promoCodeId], references: [id])
  payments   Payment[]
  assignments BookingAssignment[]
}

model BookingAssignment {
  id        String   @id @default(cuid())
  bookingId String
  userId    String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model LocationUpdate {
  id        String   @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  GCASH
  MAYA
  CARD
  CASH
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  customerId    String
  amount        Float
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  reference     String?
  gatewayRef    String?       @unique
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id          String       @id @default(cuid())
  code        String       @unique
  description String?
  type        DiscountType @default(PERCENTAGE)
  value       Float
  maxUsage    Int          @default(100)
  usedCount   Int          @default(0)
  minAmount   Float        @default(0)
  maxDiscount Float?
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bookings Booking[]
}

model CustomerNotification {
  id        String   @id @default(cuid())
  customerId String
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  customerId String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([customerId])
}
