# Supabase PostgreSQL via pooler (used at runtime by Prisma)
SUPABASE_URL="postgresql://postgres.PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma CLI migrations (same host, port 5432, no pgbouncer)
DATABASE_URL="postgresql://postgres.PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# SMTP Email (for booking confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@dropnfly.ph
SMTP_SECURE=false

# Gemini AI (for analytics predictions & chatbot)
GEMINI_API_KEY=your-gemini-api-key

# Mapbox (for live tracking maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Customer JWT Secret (used for customer portal auth)
CUSTOMER_JWT_SECRET=generate-a-random-secret-here

# PayMongo (for online payments via GCash, Maya, Card)
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_live_xxx
# PAYMONGO_SECRET_KEY=sk_live_xxx

# VAPID Keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
